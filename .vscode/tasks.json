{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Map Page",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"chmod +x scripts/run_map.sh; scripts/run_map.sh"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": true,
			"problemMatcher": {
				"owner": "custom-streamlit",
				"pattern": [
					{
						"regexp": ".*",
						"file": 1,
						"line": 1,
						"message": 0
					}
				],
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^Starting Streamlit Map on http://localhost:8501$",
					"endsPattern": "^Running on http://localhost:8501$"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "Stop Map Page",
			"type": "shell",
			"command": "bash",
			"args": [
				"-lc",
				"chmod +x scripts/stop_map.sh; scripts/stop_map.sh"
			],
			"presentation": {
				"reveal": "never",
				"panel": "shared"
			}
		}
	]
}