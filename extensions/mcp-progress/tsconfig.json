{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2021",
        "lib": [
            "ES2021",
            "DOM"
        ],
        "outDir": "out",
        "rootDir": "src",
        "sourceMap": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "src/**/*"
    ]
}
