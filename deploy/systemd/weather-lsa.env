# Example environment for systemd deployment
PROFILE=prod
HEALTH_PORT=8080
METRICS_PORT=9108
# Google Ads IDs and tokens (digits only)
GOOGLE_ADS_CUSTOMER_ID=xxxxxxxxxx
GOOGLE_ADS_CAMPAIGN_ID=yyyyyyyyyy
GOOGLE_ADS_DEVELOPER_TOKEN=zzzzzzzzzzzzzzzzzzzzzz
# Optional manager
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=mmmmmmmmm
# Feature flags
REQUIRE_LOCAL_SERVICES_ONLY=true
VALIDATE_GATE=true
SAFE_MODE=false
# Notifications
ENABLE_NOTIFICATIONS=true
ENABLE_EMAIL=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=changeme
EMAIL_FROM=user@example.com
EMAIL_TO=ops@example.com
