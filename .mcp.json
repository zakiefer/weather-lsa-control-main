{
  "servers": {
    "fs": { "type": "builtin" },
    "git": { "type": "builtin" },
    "issues": { "type": "builtin" },
    "tasks": { "type": "builtin" },

    "pytest": { "command": "pytest" },
    "coverage": { "command": "coverage run -m pytest" },

    "docker": { "command": "docker" },
    "kubernetes": { "command": "kubectl" },
    "ci": { "command": "gh workflow run" },

    "sql": { "command": "sqlite3" },
    "http": { "type": "builtin" },
    "fetch": { "type": "builtin" },
    "secrets": { "type": "builtin" },

    "browser": { "type": "remote", "name": "Playwright MCP" },
    "a11y": { "type": "remote", "name": "axe-core A11y MCP" },

    "mapbox": { "type": "remote", "name": "Mapbox MCP", "env": ["MAPBOX_ACCESS_TOKEN"] },
    "googlemaps": { "type": "remote", "name": "Google Maps MCP", "env": ["GOOGLE_MAPS_API_KEY"] },

    "google-maps": { "type": "remote", "repo": "octahaidra/google-maps-MCP", "env": ["GOOGLE_MAPS_API_KEY"] },
    "travel-planner": { "type": "remote", "name": "Travel Planner MCP", "env": ["GOOGLE_MAPS_API_KEY"] },
    "map-traveler": { "type": "remote", "name": "Map Traveler MCP" },
    "naver-map": { "type": "remote", "name": "Naver Map Direction MCP", "env": ["NAVER_MAP_GEO_API_URL", "CLIENT_ID", "CLIENT_SECRET"] },
    "playwright": { "type": "builtin" },
    "puppeteer": { "type": "builtin" },
    "mcp-browser": { "type": "remote", "name": "Puppeteer-based Browser MCP" },
    "mcp-web": { "type": "remote", "name": "Playwright-based Web Browser Server" },
    "browser-use": { "type": "remote", "name": "Vision-capable Browser Automation (Persistent)" },
    "ai-vision-debug": { "type": "remote", "name": "AI Vision Debug MCP Server" },
  "screenshot": { "type": "remote", "name": "Screenshot MCP Server" },

    "screen-capture": {
      "type": "commands",
      "commands": {
        "capture_window": { "run": ["bash", "scripts/vision/capture_window.sh", "<app>", "<out>"] },
        "capture_screen": { "run": ["bash", "scripts/vision/capture_screen.sh", "<out>"] },
        "ocr":            { "run": ["bash", "scripts/vision/ocr.sh", "<img>"] }
      }
    },

    "memory": {
      "type": "commands",
      "commands": {
        "log_jsonl": { "run": ["bash", "scripts/memory/log_jsonl.sh", "<json>"] },
        "log_quick": { "run": ["python3", "-c",
          "import json,sys; d={'goal':sys.argv[1],'step':sys.argv[2],'cmds':sys.argv[3],'files':sys.argv[4],'result':sys.argv[5],'followups':sys.argv[6]}; print(json.dumps(d))",
          "<goal>","<step>","<cmds>","<files>","<result>","<followups>"] },
        "todo_add":  { "run": ["bash", "scripts/memory/todo.sh", "add", "<text>"] },
        "todo_done": { "run": ["bash", "scripts/memory/todo.sh", "done", "<id>"] },
        "todo_list": { "run": ["bash", "scripts/memory/todo.sh", "list"] }
      }
    }
  }
}
