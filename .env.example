# Example environment variables
PROFILE=dev
DRY_RUN=true

# Health/metrics
HEALTH_PORT=8081
METRICS_PORT=9108

# Streamlit defaults (overridable)
STREAMLIT_SERVER_PORT=8510
# Google Ads config (use long names or the short aliases below)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_CAMPAIGN_ID=
GOOGLE_ADS_API_VERSION=v18
# Optional canary API version to probe and optionally promote via CLI
GOOGLE_ADS_API_VERSION_CANARY=

# Short aliases (optional)
ADS_DEV_TOKEN=
ADS_LOGIN_ID=
ADS_CUSTOMER_ID=
ADS_CAMPAIGN_ID=
ADS_API_VERSION=

# Behavior flags
DRY_RUN=true
# Either VALIDATE_ONLY or GOOGLE_ADS_VALIDATE_ONLY
VALIDATE_ONLY=false
GOOGLE_ADS_VALIDATE_ONLY=false
LIST_CAMPAIGNS=false
CREATE_TEST_ACCOUNT=false
REQUIRE_LOCAL_SERVICES_ONLY=false

# Region mappings (default enabled). Set to false to ignore DB mappings and use default IDs.
USE_REGION_MAPPINGS=true

# Profile (dev|staging|prod). In prod, app refuses to start with DRY_RUN or FORCE_ALERT.
PROFILE=dev

# Weather testing
FORCE_ALERT=false
FORCE_EVENT=Tornado Warning

# Optional filters (defined as sets in code)
# ALLOWED_SEVERITIES: {"Severe", "Extreme"}
# ALLOWED_URGENCY: {"Immediate", "Expected"}
# ALLOWED_CERTAINTY: {"Observed", "Likely"}

# Optional radius filter (disabled when MAX_DISTANCE_MI=0 or RADIUS_MI=0)
CENTER_LAT=
CENTER_LON=
MAX_DISTANCE_MI=0
RADIUS_MI=

# Hold window (hours to keep enabled after last alert)
HOLD_HOURS=24

# NWS request timeout (seconds)
NWS_TIMEOUT_SECONDS=10
TIMEOUT_SECONDS=

# Rules
RULES_FILE=

# Notifications
ENABLE_NOTIFICATIONS=false
ENABLE_EMAIL=true

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=zach@911treeremovals.com

# Metrics (Prometheus exporter)
METRICS_PORT=

# Health endpoints
HEALTH_PORT=

# Sentry (optional)
SENTRY_DSN=
SENTRY_ENV=prod
SENTRY_TRACES=0.0

# Logging
# Use --log-level and/or --json-logs flags at runtime

# Resilience & limits
ADS_QPS=2
ADS_BURST=5
ADS_BACKOFF_MAX_ATTEMPTS=5
ADS_BACKOFF_BASE_SECONDS=0.5
ADS_BACKOFF_MAX_SLEEP=10.0
ADS_BREAKER_THRESHOLD=3
ADS_BREAKER_COOLDOWN_MIN=10
ADS_BREAKER_NOTIFY_COOLDOWN_MIN=60
SAFE_MODE=false
KILL_SWITCH=false
MAX_MUTATIONS_PER_DAY=0
QUIET_HOURS=
CANARY_COUNTIES=
ALERT_SUPPRESSION_MINUTES=0
VALIDATE_GATE=true
REQUIRED_CAMPAIGN_LABELS=

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=weather-lsa-control
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# Database (optional Postgres)
DATABASE_URL=

# --- Hugging Face tokens (copy to .env.local) ---
# Used by HF client libraries and integrations
HUGGINGFACEHUB_API_TOKEN=
HF_TOKEN=

# --- OpenRouter / OpenAI-compatible (optional) ---
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --- Firecrawl (optional) ---
# FIRECRAWL_API_KEY=

# --- Microsoft Clarity MCP (optional) ---
# CLARITY_PROJECT_ID=
# CLARITY_API_TOKEN=
# CLARITY_MCP_CMD=

# --- MCP extras (optional; copy to .env.local) ---
# TAVILY_API_KEY=
# MEM0_API_KEY=
